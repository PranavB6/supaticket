{
  "name": "fastify-practice",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "start:build": "npm run build && npm run start",
    "build": "tsc --project tsconfig.build.json",
    "build:clean": "tsc --build --clean tsconfig.build.json",
    "dev": "dotenvx run -- tsx watch --tsconfig tsconfig.json src/server.ts",
    "test": "DOTENV_ENV=test dotenvx run --convention=flow -- vitest run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "migrate": "DOTENV_ENV=test dotenvx run --convention=flow -- tsx db/scripts/migrate.ts",
    "migrate:reset": "DOTENV_ENV=test dotenvx run --convention=flow -- tsx db/scripts/migrate.ts --reset",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "clean": "rimraf dist **/*.tsbuildinfo node_modules/.cache"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.48",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "close-with-grace": "^2.4.0",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "rimraf": "^6.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@faker-js/faker": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
